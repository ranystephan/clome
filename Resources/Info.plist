<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Clome</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSQuitAlwaysKeepsWindows</key>
    <false/>

    <!-- TCC usage descriptions required for sandbox entitlements -->
    <key>NSCameraUsageDescription</key>
    <string>Clome needs camera access for web pages that use video (e.g. video calls).</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Clome needs microphone access for web pages that use audio input (e.g. voice calls).</string>
    <key>NSAppleEventsUsageDescription</key>
    <string>Clome needs to send Apple Events to control other applications.</string>
    <key>NSDesktopFolderUsageDescription</key>
    <string>Clome needs access to your Desktop for project files.</string>
    <key>NSDocumentsFolderUsageDescription</key>
    <string>Clome needs access to your Documents for project files.</string>
    <key>NSDownloadsFolderUsageDescription</key>
    <string>Clome needs access to Downloads to save files from the browser.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>Clome needs local network access to connect to local development servers and allow remote control from Clome Flow on iOS.</string>

    <!-- Bonjour service types for remote control discovery -->
    <key>NSBonjourServices</key>
    <array>
        <string>_clome._tcp</string>
    </array>

    <!-- Google Sign-In URL scheme for OAuth callback -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>com.googleusercontent.apps.1004240363696-vocto1lqvl6sc0p1pqu9hl7cd6hbrir5</string>
            </array>
            <key>CFBundleURLName</key>
            <string>Google Sign-In</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
        </dict>
    </array>

    <!-- Calendar access for Flow panel -->
    <key>NSCalendarsUsageDescription</key>
    <string>Clome Flow needs calendar access to show your schedule in the Flow panel.</string>
    <key>NSCalendarsFullAccessUsageDescription</key>
    <string>Clome Flow needs calendar access to show your schedule in the Flow panel.</string>
    <key>NSRemindersUsageDescription</key>
    <string>Clome Flow needs reminders access to display your reminders in the calendar.</string>
    <key>NSRemindersFullAccessUsageDescription</key>
    <string>Clome Flow needs reminders access to display your reminders in the calendar.</string>

    <!-- WKWebView: allow loading HTTP content (for local dev servers etc.) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
